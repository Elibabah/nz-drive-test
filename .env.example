# Google Maps API Key (used for Directions API + Maps SDK)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Anthropic Claude (AI feedback + real-time examiner responses)
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI TTS (optional — makes the examiner voice sound natural instead of robotic)
# Get a key at platform.openai.com. Without this, falls back to system TTS.
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here
